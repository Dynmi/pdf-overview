OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAP_MODEL=google/gemini-2.5-flash-lite-preview-09-2025:nitro
REDUCE_MODEL=anthropic/claude-haiku-4.5:nitro
# How many map chunks to dispatch to the fast model concurrently. Raise if you see flat map latency
# — :nitro routes on Gemini Flash-Lite handle 24-32 easily. Lower if you hit rate limits.
MAP_CONCURRENCY=24
# Tesseract languages for OCR fallback on scanned PDFs (e.g. "eng", "eng+chi_sim")
OCR_LANG=eng
# DPI for rendering pages before OCR. 200 is a good quality/speed tradeoff; bump to 300 for tiny fonts.
OCR_DPI=200
# Parallel OCR workers. Defaults to CPU count. Tesseract is single-threaded per page, so more workers ≈ linear speedup up to core count.
# OCR_WORKERS=8
# Tesseract engine/page-segmentation mode. --psm 6 = "uniform block of text", fastest for book body pages.
# OCR_CONFIG=--oem 1 --psm 6
# Drop OCR'd words whose tesseract confidence is below this (0-100). Filters garbage
# gibberish out before it reaches the LLM → ~5-15% fewer input tokens on scanned PDFs.
# OCR_MIN_CONF=55
# OCR backend. Auto-detected: 'tesserocr' (C++ bindings, ~3-10× faster, optional install) preferred,
# 'pytesseract' (subprocess-per-page, always available) fallback. Force with: OCR_BACKEND=pytesseract
# OCR_BACKEND=tesserocr
# Override tessdata directory if tesserocr can't find it (common on homebrew macOS).
# macOS/ARM: /opt/homebrew/share/tessdata   macOS/Intel: /usr/local/share/tessdata
# TESSDATA_PREFIX=/opt/homebrew/share/tessdata
